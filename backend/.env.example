# PostgreSQL connection URL used by SQLAlchemy and Alembic
DATABASE_URL=postgresql+psycopg://datachain:datachain_dev@localhost:5432/datachain

# Optional: bcrypt cost factor for password hashing (4–31; default 12)
# BCRYPT_ROUNDS=12

# Required for JWT access tokens (use a long random string; never commit real secrets)
JWT_SECRET_KEY=
# Optional: access token lifetime in minutes (default 60; max 10080 = 7 days)
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
